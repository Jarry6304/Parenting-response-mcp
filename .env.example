# parenting-response-mcp 環境變數範本(完整語意見 README「env 總表」與 docs/deploy-runbook.md)
# 本機開發:只需 DATABASE_URL(AUTH_MODE 預設 local,只准綁 loopback,明文直通)。
# 雲端部署:全部必填(值放 Secret Manager,不要放 repo)。

# ── 必填 ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost/parenting_response

# ── 驗證(I 件;雲端必填) ─────────────────────────────────────
# local = 無閘只准 loopback;authkit = WorkOS OAuth(以下三項缺一拒啟動)
AUTH_MODE=local
#AUTHKIT_DOMAIN=https://your-app.authkit.app
#BASE_URL=https://your-service.run.app
#ALLOWED_SUBJECTS=user_AAA,user_BBB

# ── 多照顧者(K 件;authkit 必填) ────────────────────────────
#CAREGIVER_MAP={"user_AAA":"爸","user_BBB":"媽"}

# ── 信封加密(J 件;雲端必填,未設 = 明文直通僅限本機) ──────
# 生成:python3 -c "import base64,json,secrets;print(json.dumps({'k1':base64.b64encode(secrets.token_bytes(32)).decode()}))"
#ENVELOPE_KEYS={"k1":"<base64-32-bytes>"}
#ENVELOPE_ACTIVE_KEY_ID=k1

# ── 選填 ──────────────────────────────────────────────────────
#HOST=127.0.0.1        # 容器 = 0.0.0.0(須 AUTH_MODE=authkit)
#PORT=8000
#SESSION_TTL_DAYS=30   # 棄案 TTL(≤0 停用)
